#!/bin/bash

RED="\033[31m"
YELLOW=$'\e[33m'
RESET="\033[0m"

CONFIG_DIR="$HOME/.ghost"
CONFIG_FILE="$CONFIG_DIR/servers.conf"

mkdir -p "$CONFIG_DIR"
touch "$CONFIG_FILE"

