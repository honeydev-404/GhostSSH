then
    echo "____________________USAGE______________________"
    printf "%-25s %s\n" "ghost add"            "Add a new server"
    printf "%-25s %s\n" "ghost list"           "Show saved servers"
    printf "%-25s %s\n" "ghost <alias>"        "Connect to a server"
    printf "%-25s %s\n" "ghost remove <alias>" "Planned for v1.1"
    printf "%-25s %s\n" "ghost edit <alias>"   "Planned for v1.1"
    exit
fi 

