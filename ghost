if [ "$1" = "-l" ] || [ "$1" = "list" ]
then 
    
    printf "%-12s %-12s %-30s %-6s\n" "Alias" "Username" "Host" "Port"
    echo "--------------------------------------------------------------"
    
    while IFS="|" read -r Alias Username Host Port
    do
        printf "%-12s %-12s %-30s %-4s\n" "$Alias" "$Username" "$Host" "$Port"
    done < "$CONFIG_FILE"
    exit
fi

#ADD COMMAND
if [ "$1" != "add" ] 
then

server_search="$1"

if [ -n "$server_search" ]
then
    server_data=$(grep "^$server_search|" "$CONFIG_FILE")

    if [ -z "$server_data" ]
    then
        echo -e "${RED}[Error]${RESET} Server not found"
        exit
    fi

    IFS="|" read -r server_name username ip port <<< "$server_data"

    echo -e "Connecting to $server_name..."

    ssh -p "$port" "$username@$ip"

    exit
fi
fi

